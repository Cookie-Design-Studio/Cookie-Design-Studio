{
  "name": "@cookie-design-studio/ui",
  "version": "0.0.1",
  "description": "Shared UI primitives, tokens and styles for Cookie Design Studio.",
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "styles"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles/tokens.css": "./styles/tokens.css",
    "./styles/site-header.css": "./styles/site-header.css",
    "./styles/split-text.css": "./styles/split-text.css"
  },
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "gsap": "^3.12.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "tsup": "^8.5.1",
    "typescript": "~5.7.2"
  }
}
